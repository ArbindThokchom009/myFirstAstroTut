---
import navData from "../data/navData.js";
---

<nav>
  <ul>
    {
      navData.map((item) => (
        <li>
          <a href={item.link} aria-label={`Go to ${item.name}`}>
            {item.name}
          </a>
        </li>
      ))
    }
    <!-- <li><a href="/about" aria-label="Go to About">About</a></li>
        <li><a href="/blog" aria-label="Go to Blog">Blog</a></li> -->
  </ul>
</nav>
